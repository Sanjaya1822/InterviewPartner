# =============================================================================
# Frontend Environment Variables
# Copy this file to .env and fill in your values.
# All variables must be prefixed with VITE_ to be accessible in the browser.
# =============================================================================

# Backend API base URL
VITE_API_URL=http://localhost:8000

# WebSocket URL for real-time interview sessions
VITE_WS_URL=ws://localhost:8000

# Google OAuth2 Client ID (must match backend GOOGLE_CLIENT_ID)
VITE_GOOGLE_CLIENT_ID=your-google-client-id

# Application name shown in the UI (optional override)
VITE_APP_NAME=AI Interview Partner

# Feature flags (set to "true" to enable)
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_CODE_EDITOR=true
VITE_ENABLE_PDF_EXPORT=true
