# =============================================================================
# Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/interview_db

# -----------------------------------------------------------------------------
# Authentication / JWT
# -----------------------------------------------------------------------------
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# LLM Providers (at least one required)
# -----------------------------------------------------------------------------
# Groq — fast inference, free tier available: https://console.groq.com/
GROQ_API_KEY=your-groq-api-key

# Google Gemini (optional): https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# OpenRouter — access many models via one API: https://openrouter.ai/
OPENROUTER_API_KEY=your-openrouter-api-key

# Default LLM provider to use (groq | gemini | openrouter)
DEFAULT_LLM_PROVIDER=groq

# Default model name for the chosen provider
DEFAULT_LLM_MODEL=llama-3.1-70b-versatile

# -----------------------------------------------------------------------------
# ChromaDB — vector store
# -----------------------------------------------------------------------------
CHROMA_HOST=localhost
CHROMA_PORT=8001

# Name of the collection used to store resume embeddings
CHROMA_COLLECTION_RESUMES=resumes
CHROMA_COLLECTION_QUESTIONS=question_bank

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_CACHE_TTL=3600           # seconds (1 hour)

# -----------------------------------------------------------------------------
# Google OAuth2 (optional — enables "Sign in with Google")
# https://console.cloud.google.com/apis/credentials
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:5173
# Comma-separated list of additional allowed origins (optional)
# EXTRA_CORS_ORIGINS=https://staging.yourdomain.com,https://yourdomain.com

# -----------------------------------------------------------------------------
# File Uploads
# -----------------------------------------------------------------------------
MAX_FILE_SIZE=10485760          # 10 MB in bytes
ALLOWED_EXTENSIONS=pdf,docx
UPLOAD_DIR=./uploads            # Local path for resume storage

# -----------------------------------------------------------------------------
# Report Generation
# -----------------------------------------------------------------------------
REPORTS_DIR=./reports           # Local path for generated PDF reports

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_ENV=development             # development | staging | production
APP_VERSION=0.1.0
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR | CRITICAL
DEBUG=true                      # Set to false in production

# Celery worker concurrency
CELERY_CONCURRENCY=2

# Max questions per interview session
MAX_INTERVIEW_QUESTIONS=10

# Default interview duration (minutes)
DEFAULT_INTERVIEW_DURATION=45
