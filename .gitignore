# =============================================================================
# AI Interview Practice Partner — .gitignore
# Covers: Python (backend), Node/React (frontend), Docker, OS files
# =============================================================================

# -----------------------------------------------------------------------------
# Environment & secrets — NEVER commit these
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.production
.env.staging
backend/.env
frontend/.env
*.pem
*.key
*.cert
secrets/

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
wheels/
share/python-wheels/
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
venv/
.venv/
env/
ENV/
.env/
backend/venv/
backend/.venv/

# Testing
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
*.py,cover
nosetests.xml
pytest.xml

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/
.pyre/

# Jupyter Notebooks
.ipynb_checkpoints
*.ipynb

# pyenv
.python-version

# Celery
celerybeat-schedule
celerybeat.pid

# Alembic
# Keep migrations folder but ignore __pycache__ inside it
backend/alembic/versions/__pycache__/

# Uploads / generated files
backend/uploads/
backend/reports/
backend/tmp/
*.pdf
*.docx
!docs/**/*.pdf

# -----------------------------------------------------------------------------
# Node / React / Frontend
# -----------------------------------------------------------------------------
node_modules/
frontend/node_modules/
.npm
.yarn/
.yarn-integrity
.pnp
.pnp.js

# Build outputs
frontend/dist/
frontend/build/
frontend/.vite/
dist/
build/

# Testing
coverage/
frontend/coverage/
*.lcov
.nyc_output

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# TypeScript cache
*.tsbuildinfo
frontend/tsconfig.tsbuildinfo

# Storybook
.storybook/
storybook-static/

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
# Ignore local Docker volumes data directories
docker/data/
docker/volumes/
docker/postgres-data/
docker/chroma-data/
docker/redis-data/

# -----------------------------------------------------------------------------
# Databases & vector stores
# -----------------------------------------------------------------------------
*.sqlite
*.sqlite3
*.db
chroma_db/
chroma-data/
postgres-data/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
*.log.*
log/

# -----------------------------------------------------------------------------
# OS generated files
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
Icon

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# -----------------------------------------------------------------------------
# IDEs & editors
# -----------------------------------------------------------------------------
# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example

# JetBrains (PyCharm, WebStorm, etc.)
.idea/
*.iml
*.iws
*.ipr
out/
.idea_modules/

# Vim / Neovim
*.swp
*.swo
*.swn
Session.vim
.netrwhist

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp

# Sublime Text
*.tmlanguage.cache
*.tmPreferences.cache
*.stTheme.cache
*.sublime-workspace
*.sublime-project

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------
*.bak
*.tmp
*.temp
*.orig
*.rej
*.patch
.cache/
.parcel-cache/
.turbo/
.vercel/
.netlify/
.railway/
